{
  "booster" : ["gbtree", "dart"],
  "device" : "cpu",
  "verbosity": [0, 1, 2, 3],
  "validate_parameters": [false, true],
  "nthread": [1, 4, 8, 16],
  "disable_default_eval_metric": [false, true],

  "objective" : ["multi:softprob", "multi:softmax"],
  "num_class" : 4,
  "eta" : 0.3,
  "gamma" : 0,
  "max_depth" : 6,
  "min_child_weight" : 1,
  "max_delta_step" : 0,
  "subsample" : 1,
  "sampling_method": "uniform",
  "colsample_bytree": 1,
  "colsample_bylevel": 1,
  "colsample_bynode": 1,
  "lambda": 1,
  "alpha": 0,
  "tree_method": "auto",
  "scale_pos_weight": 1,
  "process_type" : "default",
  "grow_policy": "depthwise",
  "max_leaves": 0,
  "max_bin": 256,
  "num_parallel_tree": 1
}